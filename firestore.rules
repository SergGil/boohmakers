rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(compId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/competitions/$(compId)).data.memberIds;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'sdalin777@gmail.com';
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /competitions/{compId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.ownerId || request.auth.uid in request.resource.data.memberIds);

      match /matches/{matchId} {
        allow read: if isMember(compId);
        allow create, update: if isAdmin();

        match /predictions/{uid} {
          allow read: if isMember(compId);
          allow write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
